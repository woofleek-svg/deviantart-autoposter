# DeviantArt API Credentials
# Get these from: https://www.deviantart.com/developers/apps

# Your application's client ID
CLIENT_ID=your_client_id_here

# Your application's client secret (keep this private!)
CLIENT_SECRET=your_client_secret_here

# Tumblr API Credentials
# Get these from: https://www.tumblr.com/oauth/apps
# Follow OAuth1 flow to get access tokens

# Your Tumblr application's consumer key
TUMBLR_CONSUMER_KEY=your_tumblr_consumer_key_here

# Your Tumblr application's consumer secret (keep this private!)
TUMBLR_CONSUMER_SECRET=your_tumblr_consumer_secret_here

# Your Tumblr OAuth access token
TUMBLR_TOKEN=your_tumblr_token_here

# Your Tumblr OAuth access token secret (keep this private!)
TUMBLR_TOKEN_SECRET=your_tumblr_token_secret_here

# Your Tumblr blog name (the blog where artwork will be posted)
# Example: if your blog is https://yourblog.tumblr.com, use "yourblog"
TUMBLR_BLOG_NAME=your_blog_name_here

# Instagram API Credentials
# Get these from: https://developers.facebook.com/
# You need a Business/Creator Instagram account linked to a Facebook Page
# Follow the Instagram Graph API setup guide

# Your Facebook App ID (from App Dashboard > Settings > Basic)
INSTAGRAM_APP_ID=your_facebook_app_id_here

# Your Facebook App Secret (from App Dashboard > Settings > Basic)
INSTAGRAM_APP_SECRET=your_facebook_app_secret_here

# Your Instagram Business Account User ID
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Your Instagram long-lived access token (initial token, system will auto-refresh)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here

# Path for Instagram state file (stores token expiration info)
# This file is used to track token refresh and should persist across restarts
INSTAGRAM_STATE_FILE_PATH=./state/instagram_state.json

# Port for the backend server (optional, defaults to 3001)
PORT=3001

# DeviantArt username to monitor for new artwork
DEVIANTART_USERNAME=your_deviantart_username

# Backend URL (used for OAuth redirect URIs)
BACKEND_URL=https://api.your-domain.com

# CORS origin (your frontend URL)
FRONTEND_URL=https://your-domain.com

# Email address for Let's Encrypt certificate generation
CERTBOT_EMAIL=your-email@domain.com

# MySQL Database Configuration
# These will be used for the MySQL Docker service
DB_HOST=mysql-db
DB_PORT=3306
DB_NAME=artwork_tracker
DB_USER=artwork_user
DB_PASSWORD=CHANGE_ME_generate_a_secure_password
DB_ROOT_PASSWORD=CHANGE_ME_generate_a_secure_root_password
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CHARSET=utf8mb4