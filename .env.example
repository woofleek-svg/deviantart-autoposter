# ===========================================
# Root-level environment variables
# Used by Docker Compose and frontend build
# ===========================================

# --- Domain Configuration ---
# Your frontend domain (e.g., https://art.example.com)
FRONTEND_URL=https://your-domain.com
FRONTEND_DOMAIN=your-domain.com

# Your backend API domain (e.g., https://api.art.example.com)
BACKEND_URL=https://api.your-domain.com

# --- Frontend (Vite) Build Variables ---
# These are baked into the frontend at build time
VITE_BACKEND_URL=https://api.your-domain.com
VITE_ARTIST_USERNAME=your_deviantart_username
VITE_ARTIST_DISPLAY_NAME=Your Artist Name

# Google Analytics (optional, leave empty to disable)
VITE_GA_TRACKING_ID=

# EmailJS for contact form (optional)
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# --- Database (used by Docker Compose) ---
DB_ROOT_PASSWORD=CHANGE_ME_generate_a_secure_root_password
DB_PASSWORD=CHANGE_ME_generate_a_secure_password
DB_USER=artwork_user
DB_NAME=artwork_tracker

# --- SSL / Let's Encrypt ---
CERTBOT_EMAIL=your-email@domain.com
